# Generate a strong key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Set to 'production' for production deployments, 'development' for local dev
FLASK_ENV=development
# Optional: override the default SQLite database
# DATABASE_URL=sqlite:///instance/care_e.db

# Admin credentials — set both before running setup_db.py or deploying to production.
# ADMIN_USERNAME defaults to 'admin' if not set.
ADMIN_USERNAME=admin
# Generate a strong password: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_PASSWORD=
